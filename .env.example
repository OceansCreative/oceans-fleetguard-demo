# FleetGuard environment configuration
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# ---------------------------------------------------------------------------
# Runtime mode
# ---------------------------------------------------------------------------
# When MOCK_MODE=true the backend serves simulated vehicles moving around the
# Matsue / Yasugi / Yonago area, so the dashboard works WITHOUT a Traccar
# server. Set to false to relay a live Traccar instance.
MOCK_MODE=true

# ---------------------------------------------------------------------------
# Backend (FastAPI)
# ---------------------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Comma-separated list of allowed CORS origins for the frontend.
CORS_ORIGINS=http://localhost:3000
# Shared secret required on /api and /ws/positions. Empty = auth disabled
# (fine for the local mock); set a strong value for any exposed deployment.
API_KEY=
# Webhook POSTed when a vehicle enters a CRITICAL alert state (deduplicated per
# vehicle + alert type). Empty = no outbound notifications. Point it at your own
# receiver, a Slack/Discord incoming webhook, an email/SMS gateway, etc.
NOTIFY_WEBHOOK_URL=
# Per-client-IP request cap applied to /api and /ws/positions.
# 0 or empty = disabled (default — safe for the keyless MOCK_MODE quickstart).
# Set a positive integer (e.g. 60) for internet-exposed deployments.
RATE_LIMIT_PER_MINUTE=

# ---------------------------------------------------------------------------
# Traccar upstream (only used when MOCK_MODE=false)
# ---------------------------------------------------------------------------
TRACCAR_BASE_URL=http://traccar:8082
TRACCAR_WS_URL=ws://traccar:8082/api/socket
# Traccar account; the username is the login email.
TRACCAR_USERNAME=
TRACCAR_PASSWORD=
# How to relay live data: "ws" streams the WebSocket feed (default),
# "rest" polls the REST API on each tick.
TRACCAR_TRANSPORT=ws

# ---------------------------------------------------------------------------
# Frontend (Next.js) — variables prefixed with NEXT_PUBLIC_ are exposed to the
# browser, so they must never contain secrets.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000

# Must match the backend API_KEY when auth is enabled. This ships to the
# browser, so it only gates casual access — front a public deployment with real
# user auth / a backend-for-frontend rather than relying on it as a secret.
# NEXT_PUBLIC_API_KEY=

# Basemap. By default the app renders a self-contained offline vector style
# from bundled GeoJSON (no key, works air-gapped). For full street detail in
# production, point this at a vector-tile style — e.g. MapTiler, or a
# self-hosted Protomaps/OpenMapTiles style — including any API key:
#   MapTiler: https://api.maptiler.com/maps/streets/style.json?key=YOUR_KEY
# The provider host (e.g. api.maptiler.com) must be reachable / allowlisted.
# If the remote style fails to load, the app falls back to the offline basemap
# instead of showing a blank map.
#
# The map has a light / dark / aerial style switcher. Light and dark render
# offline by default; override either with a remote vector style. Aerial needs
# a provider (raster style / tile JSON, e.g. MapTiler hybrid) and the toggle
# stays disabled until NEXT_PUBLIC_MAP_AERIAL_URL is set.
# NEXT_PUBLIC_MAP_STYLE_URL=
# NEXT_PUBLIC_MAP_STYLE_URL_DARK=
# NEXT_PUBLIC_MAP_AERIAL_URL=https://api.maptiler.com/maps/hybrid/style.json?key=YOUR_KEY
# NEXT_PUBLIC_MAP_ATTRIBUTION=

# ---------------------------------------------------------------------------
# PostgreSQL (Traccar storage in docker-compose)
# ---------------------------------------------------------------------------
POSTGRES_DB=traccar
POSTGRES_USER=traccar
POSTGRES_PASSWORD=change-me-in-local-env
